  "keyFeatures": [
    "Unified CRUD interface for Kubernetes and OpenShift resources",
    "Support for OpenShift Container Virtualization (KubeVirt)",
    "Context managers for automatic resource lifecycle management",
    "Resource-specific functionality like pod exec and logs",
    "Class generator for automatic resource wrapper creation",
    "Fake Kubernetes client for testing without a cluster",
    "MCP (Model Context Protocol) server integration",
    "Type hints and comprehensive documentation",
    "Pytest fixtures for setup and teardown"
  ],
